profiles {

    local {
        process {
            executor = 'local'
            cpus = 24
            memory = '4 GB'
            time = '1h'
        }
    }

    slurm {
        process {
            executor = 'slurm'
            queue = 'genoa64'
            clusterOptions = '--qos=normal'
            cache = 'lenient'
            cpus = 1
            memory = '4G'
            time = '4h'
        }

        withLabel: big_mem {
            clusterOptions = '--qos=long'
            memory = '60G'
            time = '12h'
        }

        withLabel: big_cpus {
            cpus = 8
            memory = '20G'
            time = '6h'
        }
    }

    fast {
        params {
            MAFFT_OPT   = ""              // default MAFFT
            TREE_METHOD = "fasttree"
            MAX_SPR     = 2
            NCPU_GENERAX = 8
        }
    }

    precise {
        params {
            MAFFT_OPT   = "--maxiterate 1000 --localpair"  // L-INS-i
            TREE_METHOD = "iqtree2"
            MAX_SPR     = 3
            NCPU_GENERAX = 16
        }
    }
}


params {
    genefam_info  = "genefam.csv"
    infasta       = "data/input.fasta"
    pfam_db       = "/users/asebe/xgraubove/data/pfam/Pfam-A.hmm"
    domain_expand = 30
    s1_ncpu       = 4
    search_dir    = "results/search"
    cluster_dir   = "results/clusters"
    max_n         = 2000
    s2_ncpu       = 4
    s2_inflation  = 1.1
    IQTREE2_MODEL = "TEST"
    REFSPECIES    = "Mmus"
    REFNAMES      = "data/Mmus_gene_names.csv"
    SPECIES_TREE  = "data/species_tree.newick"
    SUBS_MODEL    = "LG"
}
