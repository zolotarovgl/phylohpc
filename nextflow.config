profiles {

    local {
        process {
            executor = 'local'
            ncpu = 4
            memory = '4 GB'
            time = '1h'
        }
    }

    slurm {
        process {
            executor = 'slurm'
            queue = 'genoa64'
            clusterOptions = '--qos=normal'
            cache = 'lenient'
            cpus = 1
            memory = '4G'
            time = '4h'
        }

        withLabel: big_mem {
            clusterOptions = '--qos=long'
            memory = '60G'
            time = '12h'
        }

        withLabel: big_cpus {
            cpus = 8
            memory = '20G'
            time = '6h'
        }
    }
}

report {
	file = 'report.html'
	enabled = true
	overwrite = true
}

timeline {
	file = 'timeline.html'
	enabled = true
	overwrite = true
}

trace {
    enabled = true
    file = 'trace.txt'
    overwrite = true
}


// pipeline params
params {
    genefam_info  = "genefam.csv"
    infasta       = "data/input.fasta"

	//pfam_db = "/home/grygoriyzolotarov/ant/xgraubove/data/pfam/Pfam-A.hmm"
    pfam_db       = "/users/asebe/xgraubove/data/pfam/Pfam-A.hmm"
    domain_expand = 30
    ncpu          = 4

    search_dir    = "results/search"
    cluster_dir   = "results/clusters"
    max_n         = 100
}
