profiles {
	slurm {
		process {
			executor = 'slurm'
			queue = 'genoa64'
			clusterOptions = '--qos=normal'
			cache = 'lenient'
			cpus = 1
			memory = '4G'
			time = '4h'
		}

		withLabel: big_mem {
			clusterOptions = '--qos=long'
			memory = '60G'
			time = '12h'
		}

		withLabel: big_cpus {
			cpus = 8
			memory = '20G'
			time = '6h'
		}
	}
}

report {
	enabled = true
	overwrite = true
}

timeline {
	enabled = true
	overwrite = true
}