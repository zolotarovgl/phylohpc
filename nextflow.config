profiles {
	slurm {
		process {
			executor = 'slurm'
			queue = 'genoa64'
			cache = 'lenient'
			pollInterval = '60 sec'
			clusterOptions = '--qos=pipelines'
			cpus = 1
			memory = '2G'
			time = '2h'
		}

		withLabel:big_mem {
			memory = '60G'
			time = '12h'
		}

		withLabel:big_cpus {
			cpus = 8
			memory = '20G'
			time = '6h'
		}
	}
}